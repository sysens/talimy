{
  "name": "@talimy/database",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "bunx drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bun run src/migrate.ts",
    "db:bootstrap": "bun run src/bootstrap.ts",
    "db:seed": "bun run src/seed/index.ts",
    "db:studio": "bunx drizzle-kit studio --config=drizzle.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "0.45.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.2"
  }
}
