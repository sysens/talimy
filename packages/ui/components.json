{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "aliases": {
    "components": "@talimy-ui/components",
    "utils": "@talimy-ui/lib/utils",
    "ui": "@talimy-ui/components/ui",
    "lib": "@talimy-ui/lib",
    "hooks": "@talimy-ui/hooks"
  },
  "registries": {
    "@reui": "https://reui.io/r/{style}/{name}.json",
    "@shadcnblocks": "https://shadcnblocks.com/r/{name}.json"
  }
}
