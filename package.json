{
  "name": "talimy",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "start": "turbo start",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint",
    "prepare": "git config core.hooksPath .husky || true",
    "hooks:install": "git config core.hooksPath .husky || true",
    "infra:check": "bun run tooling/scripts/check-remote-infra.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "turbo db:generate --filter=@talimy/database",
    "db:migrate": "turbo db:migrate --filter=@talimy/database",
    "db:seed": "turbo db:seed --filter=@talimy/database",
    "db:studio": "turbo db:studio --filter=@talimy/database",
    "smoke:integration:core": "bun run --cwd apps/api smoke:integration:core",
    "smoke:integration:full": "bun run --cwd apps/api smoke:integration:full",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@talimy/eslint-config": "workspace:*",
    "@talimy/typescript-config": "workspace:*",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "shadcn": "^4.1.2",
    "turbo": "^2.9.3",
    "typescript": "6.0.2"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "dependencies": {
    "@heroui/react": "^3.0.1",
    "@heroui/styles": "^3.0.1",
    "@sentry/nestjs": "^10.47.0"
  }
}
